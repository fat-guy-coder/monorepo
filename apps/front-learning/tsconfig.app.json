{
  "include": [
    "env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/**/__tests__/*"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@config/*": [
        "./config/*"
      ],
    },
    // 关键配置：启用提案阶段的语法
    "lib": [
      "ESNext",
      "DOM"
    ],
    "plugins": [
      {
        "name": "typescript-plugin-proposal-pipeline"
      }
    ]
  }
}