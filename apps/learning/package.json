{
  "name": "front-learning",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "translate": "tsx src/language/generate.ts",
    "g": "node  --import=tsx  scripts/generateRouteAndView.ts",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "gen:api": "tsx scripts/gen-api/index.ts",
    "gen:api:module": "pnpm gen:api --module"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "components": "workspace:^",
    "less": "^4.4.2",
    "pinia": "^3.0.1",
    "prismjs": "^1.29.0",
    "utils": "workspace:^",
    "vue": "3.6.0-beta.7",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/prismjs": "^1.26.5",
    "@vitejs/plugin-vue": "6.0.0-beta.2",
    "@vitejs/plugin-vue-jsx": "beta",
    "@vue/tsconfig": "^0.7.0",
    "vite-plugin-vue-devtools": "latest",
    "vue-tsc": "^2.2.2"
  }
}