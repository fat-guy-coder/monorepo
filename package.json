{
  "name": "json",
  "version": "1.0.0",
  "description": "我的项目啊",
  "main": "main.js",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.13.4",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "jiti": "^2.4.2",
    "postcss": "^8.5.8",
    "prettier": "^3.5.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "terser": "^5.44.1",
    "tsx": "^4.19.3",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2",
    "vite": "^7.2.4",
    "vite-plugin-compression2": "^2.4.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "bin": {
    "gen": "./bin/cli.js"
  },
  "scripts": {
    "front-learning:dev": "pnpm --filter front-learning run dev",
    "main:dev": "pnpm --filter main run dev",
    "fastify:dev": "pnpm --filter fastify run dev",
    "admin:dev": "pnpm --filter pure-admin-thin run dev",
    "admin:build": "pnpm --filter pure-admin-thin run build",
    "turbo:all:build": "turbo run build",
    "turbo:front-learning:build": "turbo run build --filter=front-learning",
    "turbo:project:build": "turbo run build --filter=\"$1\"",
    "front-learning:build": "pnpm --filter front-learning run build",
    "main:build": "pnpm --filter main run build",
    "all:build": "run-p \"build:**\"",
    "front-learning:preview": "pnpm --filter front-learning run preview",
    "main:preview": "pnpm --filter main run preview",
    "prod:preview": "run-p \"preview:**\"",
    "front-learning:gen": "pnpm -F front-learning g",
    "fastify:s-g": "pnpm -F fastify swagger:generate",
    "front-learning:g-a": "pnpm -F front-learning gen:api",
    "front-learning:g-a-m": "pnpm -F front-learning gen:api:module",
    "admin:g-a": "pnpm -F pure-admin-thin gen:api",
    "admin:g-a-m": "pnpm -F pure-admin-thin gen:api:module",
    "translate": "pnpm -F front-learning translate",
    "test": "test"
  },
  "keywords": [
    "前端学习网站",
    "视效介绍网站"
  ],
  "author": "嗨嗨嗨",
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "core-js",
      "es5-ext",
      "typeit",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide"
    ],
    "allowedDeprecatedVersions": {
      "are-we-there-yet": "*",
      "sourcemap-codec": "*",
      "lodash.isequal": "*",
      "domexception": "*",
      "w3c-hr-time": "*",
      "inflight": "*",
      "npmlog": "*",
      "rimraf": "*",
      "stable": "*",
      "gauge": "*",
      "abab": "*",
      "glob": "*"
    },
    "overrides": {
      "@tiptap/core": "2.27.1",
      "@tiptap/pm": "2.27.1"
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "tippy.js": "^6.3.7",
    "vue-demi": "^0.14.10",
    "vue-json-pretty": "^2.6.0",
    "yaml": "^2.8.2"
  }
}